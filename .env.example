# OpenAI Agents SDK（兼容 OpenAI 协议的网关，例如腾讯 TokenHub）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://tokenhub.tencentmaas.com/v1
OPENAI_AGENT_MODEL=deepseek-v4-flash
# 多轮对话历史持久化（按天分片，每天一个 JSON 文件；启动时只加载当天，跨天自动失忆）
OPENAI_AGENT_HISTORY_DIR=.runtime/agent-history
OPENAI_AGENT_HISTORY_MAX=20

# 腾讯云 ASR / TTS
TENCENTCLOUD_APP_ID=
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=

# 实时 ASR
ASR_ENGINE_MODEL_TYPE=16k_zh

# TTS
TTS_REGION=ap-beijing
TTS_VOICE_TYPE=101001
TTS_SAMPLE_RATE=16000
TTS_CODEC=mp3
TTS_SPEED=0

# 唤醒词
KWS_MODEL_DIR=models/sherpa-onnx-kws-zipformer-wenetspeech-3.3M-2024-01-01
KWS_KEYWORDS_FILE=models/kws/keywords-caibao.txt

# 本机音频（可选，留空则自动探测 sox/ffmpeg/afplay 等）
# AUDIO_RECORD_CMD=
# AUDIO_PLAY_CMD=

# Web Search（可选）
# 可选值：auto/duckduckgo/brave/tavily/serpapi/bing；auto 会优先使用已配置 API Key 的服务，最后回退 DuckDuckGo。
WEB_SEARCH_PROVIDER=auto
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
SERPAPI_API_KEY=
BING_SEARCH_API_KEY=

# Home Assistant（可选）
HOME_ASSISTANT_BASE_URL=
HOME_ASSISTANT_TOKEN=

# Gosund / MiHome 插线板（cuco.plug.cp5d）
# 通过 demos/xiaomi-token-by-ip.py 获取 token
GOSUND_PLUG_IP=
GOSUND_PLUG_TOKEN=

# 各房间空调（小米空调伴侣 cuco.acpartner.cp6）
AC_LIVING_ROOM_IP=
AC_LIVING_ROOM_TOKEN=
AC_MASTER_BEDROOM_IP=
AC_MASTER_BEDROOM_TOKEN=
AC_GRANDMA_ROOM_IP=
AC_GRANDMA_ROOM_TOKEN=
AC_YUYUE_ROOM_IP=
AC_YUYUE_ROOM_TOKEN=
AC_YUXIAO_ROOM_IP=
AC_YUXIAO_ROOM_TOKEN=

# 小朋友游戏机控制（Switch 接在 Gosund 插板的 s1 插孔）
# 复用上面 GOSUND_PLUG_IP / GOSUND_PLUG_TOKEN
GAME_CONSOLE_PLUG_DID=s1
GAME_DAILY_QUOTA_MINUTES=60           # 单人单日额度（分钟）
GAME_ALLOWED_WEEKDAYS=0,6             # 允许玩游戏的星期（0=周日, 6=周六）
# 到期前提醒点（秒）；默认 180,60 表示剩 3 分钟 / 1 分钟时各提醒一次
GAME_REMINDER_SECONDS=180,60
GAME_MAX_SINGLE_SESSION_MINUTES=60
GAME_MIN_SINGLE_SESSION_MINUTES=5     # 单次最少 5 分钟
GAME_QUOTA_FILE=.runtime/game-quota.json

# Langfuse trace 上报（可选）
# 配齐三项即开启；缺一项即关闭。
# - LANGFUSE_BASE_URL：自托管填你的实例地址，云端填 https://cloud.langfuse.com (EU) 或 https://us.cloud.langfuse.com (US)
# - LANGFUSE_DEBUG=1 时会打印 processor 内部告警
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=
# LANGFUSE_SERVICE_NAME=home-voice-agent
# LANGFUSE_DEBUG=0
