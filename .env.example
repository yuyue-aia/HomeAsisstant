# OpenAI Agents SDK（兼容 OpenAI 协议的网关，例如腾讯 TokenHub）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://tokenhub.tencentmaas.com/v1
OPENAI_AGENT_MODEL=deepseek-v4-flash

# 腾讯云 ASR / TTS
TENCENTCLOUD_APP_ID=
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=

# 实时 ASR
ASR_ENGINE_MODEL_TYPE=16k_zh

# TTS
TTS_REGION=ap-beijing
TTS_VOICE_TYPE=101001
TTS_SAMPLE_RATE=16000
TTS_CODEC=mp3
TTS_SPEED=0

# 唤醒词
KWS_MODEL_DIR=models/sherpa-onnx-kws-zipformer-wenetspeech-3.3M-2024-01-01
KWS_KEYWORDS_FILE=models/kws/keywords-xiaoyu.txt

# 本机音频（可选，留空则自动探测 sox/ffmpeg/afplay 等）
# AUDIO_RECORD_CMD=
# AUDIO_PLAY_CMD=

# Home Assistant（可选）
HOME_ASSISTANT_BASE_URL=
HOME_ASSISTANT_TOKEN=
